# Experient — Root .env (single source of truth for all services)
# Copy to .env and fill in your values. Never commit .env files.
#
# Both the Node.js backend and the Python agents service read from this file:
#   • Node backend:  require('dotenv').config({ path: '../../.env' }) — loads first
#   • Python agents: load_dotenv() — CWD is Experient root when started via npm run dev
#
# To generate a secure internal key:
#   openssl rand -hex 32
#
# ── Shared Secrets (read by both backend + agents) ──────────────────────────────
# CRITICAL: Both services must use the SAME value. The default below works for
# local dev with no .env file — it matches both code defaults. In staging/prod,
# override this with a strong random key and set it in both service environments.
AGENTS_INTERNAL_KEY=dev-internal-key-change-in-prod
AGENTS_URL=http://localhost:8001

# ── AI Keys ─────────────────────────────────────────────────────────────────────
# Required for AI survey generation and insights (Node backend)
OPENROUTER_API_KEY=sk-or-...

# Required for agents service in staging + prod
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/experient
AGENTS_DB_DSN=postgresql://postgres:postgres@localhost:5432/experient

# ── Redis ────────────────────────────────────────────────────────────────────────
# Optional — rate limiter falls back to in-memory (not suitable for multi-instance)
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk) ─────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
# Frontend key (set in app/.env.local, not here — Vite reads from app/)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Backend ──────────────────────────────────────────────────────────────────────
BACKEND=local
PORT=3001
# SKIP_AUTH=true    # LOCAL DEV ONLY — never set in staging/prod

# ── Agents Service ───────────────────────────────────────────────────────────────
# dev       → free OpenRouter models, colorized logs, DEBUG level, hot-reload
# dev-paid  → cheap paid OpenRouter models
# staging   → Anthropic Sonnet + Haiku (~$0.01/run)
# prod      → Anthropic Opus 4.7 + Haiku (~$0.05-0.10/run)
AGENTS_ENV=dev
AGENTS_PORT=8001
AGENTS_HOST=0.0.0.0
MAX_TOKENS_PER_RUN=50000
MAX_DAILY_SPEND_USD=0

# ── Observability ────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://...
# VITE_SENTRY_DSN=https://...    # Frontend — set in app/.env.local
