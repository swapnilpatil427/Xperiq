{
  "title": "Experient API",
  "uid": "experient-api",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "tags": ["experient"],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[2m])) by (method, route)",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2 },
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{status_code=~\"5..\"}[2m])) / sum(rate(http_requests_total[2m]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[2m])) by (le, route))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le, route))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[2m])) by (le, route))",
          "legendFormat": "p99 {{route}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "AI / OpenRouter",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "AI Request Rate",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "reqps" }
      },
      "targets": [
        {
          "expr": "sum(rate(ai_requests_total[5m])) by (model, operation)",
          "legendFormat": "{{operation}} / {{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "AI Latency (p95)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ai_request_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "p95 {{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "AI Tokens Used",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" }
      },
      "targets": [
        {
          "expr": "sum(rate(ai_tokens_total[5m])) by (model, type)",
          "legendFormat": "{{type}} / {{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Database",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "DB Query Duration (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[2m])) by (le, operation))",
          "legendFormat": "p95 {{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "DB Query Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ops" }
      },
      "targets": [
        {
          "expr": "sum(rate(db_query_duration_seconds_count[2m])) by (operation)",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Business Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Surveys Created (total)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum(surveys_created_total)", "legendFormat": "surveys", "refId": "A" }
      ]
    },
    {
      "id": 32,
      "type": "stat",
      "title": "Responses Submitted (total)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum(responses_submitted_total)", "legendFormat": "responses", "refId": "A" }
      ]
    },
    {
      "id": 33,
      "type": "stat",
      "title": "Insights Generated (total)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value", "graphMode": "area" },
      "targets": [
        { "expr": "sum(insights_generated_total)", "legendFormat": "insights", "refId": "A" }
      ]
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Business Event Rate",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ops" }
      },
      "targets": [
        { "expr": "rate(surveys_created_total[5m])", "legendFormat": "surveys created", "refId": "A" },
        { "expr": "rate(responses_submitted_total[5m])", "legendFormat": "responses submitted", "refId": "B" },
        { "expr": "rate(insights_generated_total[5m])", "legendFormat": "insights generated", "refId": "C" }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "logs",
      "title": "API Logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 49 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "expr": "{service=\"experient-api\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
