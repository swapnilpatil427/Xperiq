# Copy to .env.local — never commit the real .env.local file

# ── Auth ──────────────────────────────────────────────────────────────────────
# Clerk publishable key (safe to expose in the browser)
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── API ───────────────────────────────────────────────────────────────────────
# Backend base URL — leave blank in dev (Vite proxy handles /api → :3001)
VITE_API_URL=

# ── Observability ─────────────────────────────────────────────────────────────
# Sentry DSN — leave blank locally. Set in production to enable error reporting.
# Get from: https://sentry.io → Your Project → Settings → Client Keys (DSN)
# Free tier: 5,000 errors/month
VITE_SENTRY_DSN=
