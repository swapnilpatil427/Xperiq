# Experient Backend — .env.example
#
# Shared secrets (AGENTS_INTERNAL_KEY, AI keys, DATABASE_URL, etc.) live in the
# ROOT .env.example one level up. This file is for backend-only overrides.
# In local dev, a single root .env is sufficient — you do not need this file.
#
# If you need to override a root .env value for the backend only, copy this file
# to backend/.env and set the value here (backend .env is loaded AFTER root .env,
# so values here take precedence for the backend process).

# ── Backend-only overrides ────────────────────────────────────────────────────────
# PORT=3001
# BACKEND=local
# SKIP_AUTH=true    # LOCAL DEV ONLY

# ── All other vars live in root .env ─────────────────────────────────────────────
# See /.env.example for DATABASE_URL, AGENTS_INTERNAL_KEY, OPENROUTER_API_KEY, etc.
