# Copy to .env — choose one backend mode.

# ── Backend selector ──────────────────────────────────────────────────────────
# 'local'    → Postgres (Supabase), standalone Express server  ← for dev
# 'firebase' → Firestore, deployed as Cloud Functions          ← for prod
BACKEND=local

# ── Local mode (BACKEND=local) ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/experient
PORT=3001
SKIP_AUTH=true          # bypass Clerk; req.userId='dev-user', req.orgId='dev-org'

# ── Firebase mode (BACKEND=firebase) ─────────────────────────────────────────
# These are auto-injected by the Cloud Functions runtime when deployed.
# Only needed if running firebase emulators locally.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ── Auth (needed when SKIP_AUTH is not true) ──────────────────────────────────
CLERK_SECRET_KEY=sk_test_...

# ── AI (shared across both modes) ────────────────────────────────────────────
# Required — all AI calls route through OpenRouter (free tier available)
# Get your key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-...

# Optional — only needed for direct OpenAI SDK calls.
# OpenAI models via OpenRouter (e.g. "openai/gpt-4o") use OPENROUTER_API_KEY instead.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Internal service auth ─────────────────────────────────────────────────────
# Shared secret between this backend and the Python agents service.
# MUST match AGENTS_INTERNAL_KEY in the root .env (agents reads from there).
# Do NOT set this in backend/.env — set it only in the root /Experient/.env so
# both services read the same value. The default below is fine for local dev
# when neither service has an explicit key set.
# In prod: generate with `openssl rand -hex 32`, set in root .env only.
# AGENTS_INTERNAL_KEY=dev-internal-key-change-in-prod

# ── Error monitoring ─────────────────────────────────────────────────────────
# Sentry DSN — leave blank locally. Set in production to enable error reporting.
# Get from: https://sentry.io → Your Project → Settings → Client Keys (DSN)
# Free tier: 5,000 errors/month
SENTRY_DSN=

# ── Logging & Observability ───────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Loki push endpoint — app pushes logs directly, works on any host including serverless
#   Local Docker:    http://localhost:3100
#   Grafana Cloud:   https://logs-prod-XXX.grafana.net  (copy from your stack page)
# Leave blank to log to stdout only (Firebase Cloud Logging picks up stdout automatically)
LOKI_URL=http://localhost:3100

# Grafana Cloud Loki auth — only needed when LOKI_URL points to Grafana Cloud
# LOKI_USER=123456          (your numeric Grafana Cloud user ID)
# LOKI_PASSWORD=glc_...     (your Grafana Cloud API token)
