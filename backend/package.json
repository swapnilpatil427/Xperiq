{
  "name": "experient-api",
  "description": "Experient API — BACKEND=local (postgres) or BACKEND=firebase (Cloud Functions)",
  "version": "2.0.0",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "ENABLE_EVENT_ENGINE=true tsx src/index.ts",
    "dev": "ENABLE_EVENT_ENGINE=true tsx watch src/index.ts",
    "start:event-engine": "tsx src/eventEngine/index.ts",
    "start:scheduler": "tsx src/scheduler/index.ts",
    "sync:clerk": "tsx scripts/sync-clerk.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "deploy": "firebase deploy --only functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:agents": "cd .. && PYTHONPATH=. AGENTS_ENV=${AGENTS_ENV:-dev} REDIS_URL=redis://localhost:6379 ENABLE_STREAM_CONSUMER=true crystalos/.venv/bin/python -m uvicorn crystalos.main:app --host 0.0.0.0 --port 8001 --reload --loop asyncio",
    "start:agents:dev-paid": "cd .. && PYTHONPATH=. AGENTS_ENV=dev-paid REDIS_URL=redis://localhost:6379 ENABLE_STREAM_CONSUMER=true crystalos/.venv/bin/python -m uvicorn crystalos.main:app --host 0.0.0.0 --port 8001 --reload --loop asyncio",
    "start:full": "concurrently --names 'backend,crystalos' --prefix-colors 'blue,green' 'npm run start' 'npm run start:agents'",
    "start:full:dev-paid": "concurrently --names 'backend,crystalos' --prefix-colors 'blue,green' 'npm run start' 'npm run start:agents:dev-paid'",
    "seed:support": "tsx src/data/seed-support-docs.ts"
  },
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "@novu/framework": "^2.6.0",
    "@novu/node": "^2.6.0",
    "@sentry/node": "^10.53.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "ioredis": "^5.4.1",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "pdfmake": "^0.3.11",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-loki": "^2.3.0",
    "pptxgenjs": "^4.0.1",
    "prom-client": "^15.1.0",
    "undici": "^6.25.0",
    "uuid": "^9.0.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.0",
    "@types/node-fetch": "^2.6.11",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^8.2.2",
    "light-my-request": "^6.6.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^11.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.6"
  }
}
