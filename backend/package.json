{
  "name": "experient-api",
  "description": "Experient API — BACKEND=local (postgres) or BACKEND=firebase (Cloud Functions)",
  "version": "2.0.0",
  "engines": {
    "node": ">=20"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "deploy": "firebase deploy --only functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:agents": "cd .. && ENABLE_STREAM_CONSUMER=true agents/.venv/bin/python -m uvicorn agents.main:app --host 0.0.0.0 --port 8001 --reload --loop asyncio",
    "start:full": "concurrently --names 'backend,agents' --prefix-colors 'blue,green' 'npm run start' 'npm run start:agents'"
  },
  "dependencies": {
    "@clerk/backend": "^1.0.0",
    "@sentry/node": "^10.53.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "ioredis": "^5.4.1",
    "multer": "^2.1.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-loki": "^2.3.0",
    "prom-client": "^15.1.0",
    "undici": "^6.25.0",
    "uuid": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^8.2.2",
    "light-my-request": "^6.6.0",
    "nodemon": "^3.1.0",
    "pino-pretty": "^11.0.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}
