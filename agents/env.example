# Agents service .env.example
#
# In local dev, these vars are typically set in the ROOT .env (one level up at
# /Experient/.env). The agents service picks them up via load_dotenv() because
# its CWD is the Experient root when started by `npm run dev`.
#
# Only copy this file to agents/.env if you need to override root .env values
# specifically for the agents service process.
#
# ── Environment ────────────────────────────────────────────────────────────────
# dev       → free OpenRouter models, colorized logs, DEBUG level, hot-reload
# dev-paid  → cheap paid OpenRouter models, JSON logs, INFO level
# staging   → Anthropic Sonnet + Haiku, JSON logs, INFO level (~$0.01/run)
# prod      → Anthropic Opus 4.7 + Haiku, JSON logs, INFO level (~$0.05-0.10/run)
AGENTS_ENV=dev

# ── LLM Keys ───────────────────────────────────────────────────────────────────
# Required for ALL envs (OpenRouter is used for QC agent in every env)
OPENROUTER_API_KEY=sk-or-...

# Required for staging + prod (Anthropic SDK for creator, validator, compliance, recommender)
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────────────────────────────────
# Same Postgres instance as the Node.js backend
AGENTS_DB_DSN=postgresql://postgres:postgres@localhost:5432/experient

# ── Security ───────────────────────────────────────────────────────────────────
# Shared secret between Node.js backend and agents service.
# MUST match AGENTS_INTERNAL_KEY in root .env (and in agentsClient.js default).
# Default below works for local dev with no .env at all (matches code default).
# In staging/prod: generate with `openssl rand -hex 32` and set in both services.
AGENTS_INTERNAL_KEY=dev-internal-key-change-in-prod

# ── Limits ─────────────────────────────────────────────────────────────────────
MAX_TOKENS_PER_RUN=50000
MAX_DAILY_SPEND_USD=0

# ── Server ─────────────────────────────────────────────────────────────────────
AGENTS_PORT=8001
AGENTS_HOST=0.0.0.0
