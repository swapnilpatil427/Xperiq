# Agents service .env.example
#
# In local dev, these vars are typically set in the ROOT .env (one level up at
# /Experient/.env). The agents service picks them up via load_dotenv() because
# its CWD is the Experient root when started by `npm run dev`.
#
# Only copy this file to agents/.env if you need to override root .env values
# specifically for the agents service process.
#
# ── Environment ────────────────────────────────────────────────────────────────
# dev       → free OpenRouter models, colorized logs, DEBUG level, hot-reload
# dev-paid  → cheap paid OpenRouter models, JSON logs, INFO level
# staging   → Anthropic Sonnet + Haiku, JSON logs, INFO level (~$0.01/run)
# prod      → Anthropic Opus 4.7 + Haiku, JSON logs, INFO level (~$0.05-0.10/run)
AGENTS_ENV=dev

# ── LLM Keys ───────────────────────────────────────────────────────────────────
# Required for ALL envs — all models route through OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Optional — only needed if adding direct OpenAI SDK calls (not required for
# OpenAI models routed via OpenRouter, e.g. "openai/gpt-4o" in models.py)
OPENAI_API_KEY=sk-...

# Required for staging + prod (Anthropic SDK for creator, validator, compliance, recommender)
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ───────────────────────────────────────────────────────────────────
# Same Postgres instance as the Node.js backend
AGENTS_DB_DSN=postgresql://postgres:postgres@localhost:5432/experient

# ── Security ───────────────────────────────────────────────────────────────────
# Shared secret between Node.js backend and agents service.
# MUST match AGENTS_INTERNAL_KEY in root .env (and in agentsClient.js default).
# Default below works for local dev with no .env at all (matches code default).
# In staging/prod: generate with `openssl rand -hex 32` and set in both services.
AGENTS_INTERNAL_KEY=dev-internal-key-change-in-prod

# ── Limits ─────────────────────────────────────────────────────────────────────
MAX_TOKENS_PER_RUN=50000
MAX_DAILY_SPEND_USD=0

# ── Checkpoint blob storage ────────────────────────────────────────────────────
# dev / dev-paid → blobs written to CHECKPOINT_LOCAL_PATH (no OCI needed)
# staging / prod → blobs written to OCI Object Storage when bucket vars are set;
#                  falls back to local path with a warning if OCI is unavailable.
#
# Local path used in dev and as fallback.
CHECKPOINT_LOCAL_PATH=/tmp/checkpoints
#
# OCI Object Storage (staging/prod). Leave blank to use local filesystem.
# Bucket is created by `terraform apply` — copy values from terraform output.
CHECKPOINT_OCI_BUCKET=
CHECKPOINT_OCI_NAMESPACE=
CHECKPOINT_OCI_REGION=ap-sydney-1

# ── Crystal ReAct streaming ────────────────────────────────────────────────────
# Set to true to route CrystalAgent.run() through the ReAct loop instead of the
# single-call path. The SSE streaming endpoint (/insights/crystal/stream) always
# uses the ReAct loop regardless of this flag.
CRYSTAL_STREAMING_ENABLED=false

# ── Server ─────────────────────────────────────────────────────────────────────
AGENTS_PORT=8001
AGENTS_HOST=0.0.0.0

# ── Scheduler ──────────────────────────────────────────────────────────────────
# URL the scheduler uses to reach the agents FastAPI service (itself, or a remote).
# Default matches AGENTS_PORT above for local dev.
AGENTS_URL=http://localhost:8001

# ── Langfuse LLM Observability ─────────────────────────────────────────────────
# Every LLM call, pipeline run, Crystal session, and skill execution appears
# in Langfuse as a structured trace with prompts, responses, cost, and latency.
# Sign up: langfuse.com (free tier: 50k traces/month) or self-host.
# After adding keys: pip install langfuse (or: pip install -r requirements.txt)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com    # or your self-hosted URL